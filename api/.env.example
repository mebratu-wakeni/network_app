# Example env for api (do NOT commit secrets)
# Multi-tenant cloud (server.masatechplc.com): use Postgres via DATABASE_URL or DB_*.

DATABASE_URL=postgresql://postgres:postgres@db:5432/pharma_dev
PORT=4000

# Extra browser origins (comma-separated). Electron uses app://local (built-in).
# /admin is same-origin so it does not need CORS. Add Electron / other hosts if needed.
FRONTEND_ORIGIN=https://server.masatechplc.com

# Optional DB components if you prefer separate vars (used when DATABASE_URL is unset)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pharma_db

# License validation server (if product still calls license-api).
# Dev:  http://localhost:4001
# Prod: https://admin.mltplc.com
LICENSE_SCRIPT_URL=http://localhost:4001

# JWT signing secret — tenant logins AND platform-admin (masatech-admin).
# MUST be a long random value in production.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Optional: absolute path to built masatech-admin SPA.
# Tarball deploy embeds files at api/admin-dist (default). Only set if layout differs.
# ADMIN_STATIC_DIR=/home/USER/network-desktop-app/api/admin-dist

NODE_ENV=production

# Optional: reject Electron clients older than this semver (HTTP 426 CLIENT_OUTDATED).
# Leave unset to allow all versions. Packaged apps send X-Client-Version on every API call.
# Keep in sync with latest.json minSupportedVersion when you force a required update.
# MIN_SUPPORTED_CLIENT_VERSION=1.0.3
