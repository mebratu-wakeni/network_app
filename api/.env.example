# Example env for api (do NOT commit secrets)
DATABASE_URL=postgresql://postgres:postgres@db:5432/pharma_dev
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Optional DB components if you prefer separate vars
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pharma_db

# License validation server.
# Dev:  http://localhost:4001   (license-api running locally)
# Prod: https://admin.mltplc.com   (license-api deployed — no path suffix needed)
LICENSE_SCRIPT_URL=http://localhost:4001

# JWT signing secret, shared by tenant user logins AND platform-admin (masatech-admin) logins.
# The `type: 'platform_admin'` claim keeps the two kinds of tokens from being used
# interchangeably even though they share this secret. MUST be a long random value in production.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
