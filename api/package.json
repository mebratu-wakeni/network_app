{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src --exec \"node src/index.js\"",
    "migrate": "./node_modules/.bin/knex --knexfile db/knexfile.js migrate:latest",
    "rollback": "./node_modules/.bin/knex --knexfile db/knexfile.js migrate:rollback",
    "seed": "./node_modules/.bin/knex --knexfile db/knexfile.js seed:run",
    "db:reset": "node scripts/reset-db.js",
    "db:reset:seed": "node scripts/reset-db.js --seed",
    "db:diagnose-ledger": "node scripts/diagnose-ledger.js",
    "db:clear-financial": "node scripts/clear-financial-data.js",
    "db:reset-operational-full": "node scripts/clear-financial-data.js --yes --scope=full",
    "db:audit-fy": "node scripts/audit-fiscal-year-coverage.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration --passWithNoTests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "sqlite3": "^5.1.7",
    "sharp": "^0.34.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^0.34.6",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "vitest": "^0.34.6"
  },
  "private": true
}
