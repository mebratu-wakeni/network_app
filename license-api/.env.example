PORT=4001
NODE_ENV=development

# Path to the SQLite database file (relative to project root)
DB_PATH=db/license.db

# Secret used to sign admin JWTs — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# Comma-separated origins allowed by CORS
# Add admin.mltplc.com in production
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:4001
